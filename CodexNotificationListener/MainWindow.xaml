<Window
    x:Class="CodexNotificationListener.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Codex Notification Listener">
    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
        <TextBlock Text="Codex Notification Listener" FontSize="24" FontWeight="SemiBold" />
        <TextBlock x:Name="StatusText"
                   Grid.Row="1"
                   TextWrapping="Wrap"
                   FontSize="15" />
        <TextBlock x:Name="DetailsText"
                   Grid.Row="2"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Opacity="0.78" />
        <ScrollViewer Grid.Row="3" Margin="0,8,0,0">
            <TextBlock x:Name="RecentLogText"
                       TextWrapping="Wrap"
                       FontFamily="Consolas"
                       FontSize="12" />
        </ScrollViewer>
    </Grid>
</Window>
